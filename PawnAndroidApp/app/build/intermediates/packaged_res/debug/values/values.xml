<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_card">#FFFFFF</color>
    <color name="bg_dark">#F0F4F8</color>
    <color name="blue">#1D4ED8</color>
    <color name="card_border">#E2E8F0</color>
    <color name="gold">#B45309</color>
    <color name="gold_dark">#92400E</color>
    <color name="green">#15803D</color>
    <color name="orange">#C2410C</color>
    <color name="red">#B91C1C</color>
    <color name="white">#0F172A</color>
    <color name="white38">#94A3B8</color>
    <color name="white54">#64748B</color>
    <string name="app_name">Rajeshwari Pawn</string>
    <style name="ActionBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:backgroundTint">@color/bg_card</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="Chip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/chip_unselected</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/white54</item>
        <item name="android:textSize">12sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
    <style name="SectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textColor">@color/gold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="StatCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">14dp</item>
    </style>
    <style name="Theme.PawnApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.PawnApp.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="ToolbarTheme" parent="ThemeOverlay.AppCompat.ActionBar"/>
</resources>