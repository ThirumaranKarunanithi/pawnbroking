<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.PawnApp"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" android:exported="false" />
        <activity android:name=".HomeActivity" android:exported="false" />
        <activity android:name=".BillsActivity" android:exported="false" />
        <activity android:name=".BillDetailActivity" android:exported="false" />
        <activity android:name=".TodaysAccountActivity" android:exported="false" />
        <activity android:name=".AccountDetailActivity"  android:exported="false" />
        <activity android:name=".StockDetailsActivity"   android:exported="false" />
        <activity android:name=".MonthlyReportActivity"  android:exported="false" />
        <activity android:name=".TrialBalanceActivity"   android:exported="false" />
        <activity android:name=".CustomersActivity"      android:exported="false" />

    </application>

</manifest>
