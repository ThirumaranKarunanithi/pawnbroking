<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_card"
        android:theme="@style/ToolbarTheme"
        app:titleTextColor="@color/gold" />

    <!-- ═══ Filter Card ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Row 1: Company name + Filters toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCompanyName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnToggleFilters"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:backgroundTint="@color/gold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Filters ▼"
                android:textColor="#0D1B2A"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Collapsible filter panel ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutFilterContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- View mode: Company | Repledge | All Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnModeCompany"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/gold"
                    android:text="Company"
                    android:textColor="#0D1B2A"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnModeRepledge"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#1E2A4A"
                    android:text="Repledge"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/btnModeAll"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#1E2A4A"
                    android:text="All Details"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Material type (hidden for Repledge mode) -->
            <LinearLayout
                android:id="@+id/layoutMaterial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Material:"
                    android:textColor="@color/white54"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinnerMaterial"
                    android:layout_width="130dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_card"
                    android:popupBackground="@color/bg_card" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/card_border" />

            <!-- Filter type spinner + Add button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spinnerFilterType"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:popupBackground="@color/bg_card" />

                <Button
                    android:id="@+id/btnAddFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:backgroundTint="@color/gold"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="+ Add"
                    android:textColor="#0D1B2A"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Date range input (shown for date filter types) -->
            <LinearLayout
                android:id="@+id/layoutDateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etDateFrom"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:focusable="false"
                    android:hint="From (yyyy-MM-dd)"
                    android:inputType="none"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white54"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etDateTo"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_input"
                    android:focusable="false"
                    android:hint="To (yyyy-MM-dd)"
                    android:inputType="none"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white54"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Amount range input -->
            <LinearLayout
                android:id="@+id/layoutAmountInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etAmountFrom"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="Amount from"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white54"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etAmountTo"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_input"
                    android:hint="Amount to"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white54"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Name / text input (Customer Name or Repledge Name) -->
            <EditText
                android:id="@+id/etNameInput"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="Enter name…"
                android:inputType="textCapWords"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white54"
                android:textSize="11sp"
                android:visibility="gone" />

            <!-- Active filter chips row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutFilterChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Clear all filters button -->
            <Button
                android:id="@+id/btnClearAllFilters"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/red"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Clear All Filters"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>
        <!-- ── End collapsible panel ─────────────────────────────────────────── -->

        <!-- Search box (always visible) -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="Search bill / customer / area…"
            android:inputType="text"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/white"
            android:textColorHint="@color/white54"
            android:textSize="13sp" />

    </LinearLayout>
    <!-- ═══ End Filter Card ═══════════════════════════════════════════════════ -->

    <!-- Summary bar -->
    <LinearLayout
        android:id="@+id/layoutSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E2A4A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSummaryCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/gold"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSummaryAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/blue"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSummaryInterest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/green"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/gold"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

</LinearLayout>
