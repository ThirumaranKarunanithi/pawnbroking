<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="400.0" styleClass="modal-dialog" stylesheets="@recievedandbalance.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="billcalculator.RecievedAndBalanceAmtDialog">
   <children>
      <BorderPane styleClass="screen-background" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <Label id="alert" fx:id="lbMsg" maxHeight="1.7976931348623157E308" prefWidth="255.0">
                     <HBox.margin>
                        <Insets bottom="5.0" right="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="3.0" top="3.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <center>
            <HBox spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox alignment="TOP_RIGHT" spacing="50.0">
                     <children>
                        <Label contentDisplay="RIGHT" layoutX="24.0" layoutY="10.0" text="Actual Amount:" />
                        <Label fx:id="lbAmtRecieved" contentDisplay="RIGHT" text="Amount Recieved:" />
                        <Label fx:id="lbBalance" contentDisplay="RIGHT" text="Balance To Give:" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_RIGHT" minWidth="250.0" spacing="40.0">
                     <children>
                        <TextField fx:id="txtActualAmt" editable="false" focusTraversable="false" onKeyTyped="#allowNumberOnlyOnType" promptText="Actual Amount To Get" styleClass="custom-text-field" />
