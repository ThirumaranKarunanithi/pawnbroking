                        <TextField fx:id="txtBalanceAmt" editable="false" focusTraversable="false" onKeyTyped="#allowDotWithNumberOnType" promptText="Balance amount to give" styleClass="custom-text-field" />
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
               </children>
               <BorderPane.margin>
                  <Insets left="10.0" />
               </BorderPane.margin>
            </HBox>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#onDoneClicked" text="Done" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
