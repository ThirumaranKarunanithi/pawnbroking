<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="300.0" styleClass="screen-background" stylesheets="@billeditoperation.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="billeditoperation.BillEditOperationDialogUIController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <Label id="alert" fx:id="lbMsg" maxHeight="1.7976931348623157E308" prefWidth="255.0">
                     <HBox.margin>
                        <Insets bottom="5.0" right="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="3.0" top="3.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <center>
            <HBox spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox alignment="TOP_RIGHT" spacing="50.0">
                     <children>
                        <Label contentDisplay="RIGHT" text="Bill Number:" />
                        <Label contentDisplay="RIGHT" layoutX="30.0" layoutY="10.0" text="Date:" />
                        <Label contentDisplay="RIGHT" layoutX="10.0" layoutY="10.0" text="Tot Amount:" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_RIGHT" minWidth="200.0" spacing="40.0">
                     <children>
                        <TextField fx:id="txtAABillNumber" editable="false" focusTraversable="false" layoutX="10.0" layoutY="75.0" mouseTransparent="true" onKeyTyped="#capitalizeCharOnType" promptText="Bill Number" />
                        <DatePicker fx:id="dpAADate" editable="false" prefHeight="25.0" prefWidth="200.0" promptText="Bill closing date" />
                        <TextField fx:id="txtAATotalAmount" editable="false" focusTraversable="false" mouseTransparent="true" onKeyTyped="#capitalizeCharOnType" promptText="Total Amount" />
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
               </children>
               <BorderPane.margin>
                  <Insets left="10.0" />
               </BorderPane.margin>
            </HBox>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#onSaveClicked" text="Save" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
