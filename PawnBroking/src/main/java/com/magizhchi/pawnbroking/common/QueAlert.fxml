<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" minWidth="400.0" stylesheets="@alert.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="common.QueAlertUIController">
   <children>
      <BorderPane layoutX="183.0" layoutY="91.0" style="-fx-background-color: #f2f5b1;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT" BorderPane.alignment="TOP_RIGHT">
               <padding>
                  <Insets right="5.0" top="5.0" />
               </padding>
            </HBox>
         </top>
         <left>
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER">
               <image>
                  <Image url="@que.gif" />
               </image>
               <BorderPane.margin>
                  <Insets right="10.0" />
               </BorderPane.margin>
            </ImageView>
         </left>
         <center>
            <Label fx:id="message" textAlignment="JUSTIFY" BorderPane.alignment="CENTER">
               <padding>
                  <Insets right="10.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="50.0" />
               </BorderPane.margin></Label>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" spacing="20.0" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#byesclicked" text="Yes" />
                  <Button mnemonicParsing="false" onAction="#bnoclicked" text="No" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="10.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
