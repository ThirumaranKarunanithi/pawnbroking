<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="600.0" styleClass="credit-screen-background" stylesheets="@billclosing.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="companybillclosing.CustomerCopyUIController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <Label id="alert" fx:id="lbMsg" maxHeight="1.7976931348623157E308" prefWidth="255.0">
                     <HBox.margin>
                        <Insets bottom="5.0" right="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="3.0" top="3.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <center>
            <HBox spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox alignment="CENTER_RIGHT" spacing="50.0">
                     <children>
                        <Label contentDisplay="RIGHT" text="Govternment Id Proof Xerox Received:">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font></Label>
                        <Label contentDisplay="RIGHT" text="Id Number:">
                           <font>
                              <Font size="14.0" />
                           </font></Label>
                     </children>
                  </VBox>
                  <VBox alignment="TOP_RIGHT" minWidth="200.0" prefWidth="300.0" spacing="40.0">
                     <children>
                        <ComboBox fx:id="cbIdType" prefWidth="300.0" value="ADHAR CARD" visibleRowCount="6">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="ADHAR CARD" />
                                 <String fx:value="RATION CARD" />
                                 <String fx:value="PAN CARD" />                                 
                                 <String fx:value="VOTER ID" />
                                 <String fx:value="DRIVING LICENSE" />                                                                                                           
                              </FXCollections>
                           </items>
                        </ComboBox>
                        <TextField fx:id="txtIdNumber" onKeyPressed="#capitalizeCharOnPressed" onKeyTyped="#capitalizeCharOnType" promptText="Item" styleClass="custom-text-field" />
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
               </children>
               <BorderPane.margin>
                  <Insets left="10.0" />
               </BorderPane.margin>
            </HBox>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" spacing="20.0" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#onSaveClicked" text="Save" />
                  <Button layoutX="549.0" layoutY="30.0" mnemonicParsing="false" onAction="#onCancelClicked" text="Cancel" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
