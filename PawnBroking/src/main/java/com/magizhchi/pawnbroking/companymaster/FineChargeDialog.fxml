<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="400.0" styleClass="credit-screen-background" stylesheets="@companymaster.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="companymaster.FineChargeDialogUIController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <Label id="alert" fx:id="lbMsg" maxHeight="1.7976931348623157E308" prefWidth="255.0">
                     <HBox.margin>
                        <Insets bottom="5.0" right="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="3.0" top="3.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <center>
            <HBox spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox alignment="CENTER_RIGHT" spacing="50.0">
                     <children>
                        <Label contentDisplay="RIGHT" text="Material:" />
                        <Label contentDisplay="RIGHT" text="Interest Type:" />
                        <Label contentDisplay="RIGHT" text="From:" />
                        <Label contentDisplay="RIGHT" text="To:" />
                        <Label contentDisplay="RIGHT" layoutX="10.0" layoutY="311.0" text="Calculation Type:" />
                        <Label contentDisplay="RIGHT" text="Interest To Charged:" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_RIGHT" minWidth="250.0" spacing="40.0">
                     <children>
                        <ComboBox fx:id="cbBillMaterialType" prefWidth="250.0" value="GOLD" visibleRowCount="5">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="GOLD" />
                                 <String fx:value="SILVER" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                        <ComboBox fx:id="cbInterestType" prefWidth="250.0" value="MONTH" visibleRowCount="6">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="MONTH" />
                                 <String fx:value="DAY" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                        <TextField fx:id="txtFrom" onKeyTyped="#allowDotWithNumberOnType" promptText="Amount from" styleClass="custom-text-field" />
                        <TextField fx:id="txtTo" onKeyTyped="#allowDotWithNumberOnType" promptText="Amount to" styleClass="custom-text-field" />
                        <ComboBox fx:id="cbCalculationType" layoutX="10.0" layoutY="10.0" prefWidth="250.0" value="GOLD" visibleRowCount="5">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="ALL MONTHS" />
                                 <String fx:value="REMAINING MONTHS" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                        <TextField fx:id="txtFineCharge" onKeyTyped="#allowDotWithNumberOnType" promptText="Fine charge" styleClass="custom-text-field" />
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
               </children>
               <BorderPane.margin>
                  <Insets left="10.0" />
               </BorderPane.margin>
            </HBox>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#onSaveClicked" text="Save" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
