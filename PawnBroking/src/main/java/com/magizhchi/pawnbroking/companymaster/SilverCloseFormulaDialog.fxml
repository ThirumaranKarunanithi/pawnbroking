<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" styleClass="modal-dialog" stylesheets="@silver.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="companymaster.SilverCloseFormulaDialogUIController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <Label id="alert" fx:id="alert" maxHeight="1.7976931348623157E308" prefWidth="255.0">
                     <HBox.margin>
                        <Insets bottom="5.0" right="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="3.0" top="3.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <center>
            <VBox>
               <children>
                  <HBox alignment="TOP_CENTER" spacing="10.0" BorderPane.alignment="CENTER">
                     <children>
                        <VBox alignment="TOP_RIGHT" spacing="50.0">
                           <children>
                              <Label contentDisplay="RIGHT" text="From Date:" />
                              <Label contentDisplay="RIGHT" text="To Date:" />
                              <Label contentDisplay="RIGHT" text="From:" />
                              <Label contentDisplay="RIGHT" text="To:" />
                              <Label contentDisplay="RIGHT" text="Formula:" />
                           </children>
                           <padding>
                              <Insets left="20.0" top="10.0" />
                           </padding>
                        </VBox>
                        <VBox alignment="TOP_RIGHT" minWidth="200.0" spacing="45.0">
                           <children>
                              <DatePicker fx:id="dpFromDate" editable="false" prefWidth="344.0" promptText="From Date" />
                              <DatePicker fx:id="dpToDate" editable="false" prefWidth="344.0" promptText="To Date" />
                              <TextField fx:id="txtFrom" onKeyTyped="#allowNumberOnlyOnType" promptText="From" styleClass="custom-text-field" />
                              <TextField fx:id="txtTo" onKeyTyped="#allowNumberOnlyOnType" promptText="To" styleClass="custom-text-field" />
                              <HBox>
                                 <children>
                                    <TextField fx:id="txtFormula" editable="false" minWidth="300.0" promptText="Formula" styleClass="custom-text-field" HBox.hgrow="ALWAYS" />
                                    <Button fx:id="bErase" mnemonicParsing="false" onAction="#bEraseOnActionListener" text="Erase" />
                                 </children>
                              </HBox>
                           </children>
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                           <HBox.margin>
                              <Insets right="20.0" />
                           </HBox.margin>
                        </VBox>
                     </children>
                     <padding>
                        <Insets bottom="5.0" />
                     </padding>
                  </HBox>
                  <VBox>
                     <children>
                        <HBox spacing="20.0">
                           <children>
                                <ComboBox fx:id="cbSymbols" minWidth="70.0" onAction="#cbSymbolsOnAction">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="+" />
                                            <String fx:value="-" />
                                            <String fx:value="*" />
                                            <String fx:value="/" />
                                            <String fx:value="(" />
                                            <String fx:value=")" />
                                            <String fx:value="((" />
                                            <String fx:value="))" />                                            
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="SYMBOLS" />
                                    </value>
                              </ComboBox>
                              <ComboBox fx:id="cbOthers" minWidth="150.0" onAction="#cbOthersOnAction">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="AMOUNT" />
                                            <String fx:value="INTEREST" />
                                            <String fx:value="DOCUMENT_CHARGE" />
                                            <String fx:value="TAKEN_MONTHS" />
                                            <String fx:value="TAKEN_DAYS" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="CALCULATED RESULT" />
                                    </value>                                  
                              </ComboBox>
                              <TextField fx:id="txtValues" minWidth="100.0" onAction="#valuesOnActionListener" onKeyTyped="#allowNumberOnlyOnType" promptText="Values" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets left="20.0" right="20.0" top="40.0" />
                     </padding>
                  </VBox>
               </children>
            </VBox>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button fx:id="bSave" mnemonicParsing="false" onAction="#onSaveClicked" text="Save" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
