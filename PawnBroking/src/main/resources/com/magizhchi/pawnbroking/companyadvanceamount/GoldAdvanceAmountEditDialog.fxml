<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="400.0" styleClass="modal-dialog" stylesheets="@golddialog.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.magizhchi.pawnbroking.companyadvanceamount.GoldAdvanceAmountEditDialogUIController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="TOP_RIGHT">
               <children>
                  <Label id="alert" fx:id="lbMsg" maxHeight="1.7976931348623157E308" style="-fx-text-fill: #FF0000;">
                     <HBox.margin>
                        <Insets bottom="5.0" right="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" />
               </padding>
               <BorderPane.margin>
                  <Insets right="3.0" top="3.0" />
               </BorderPane.margin>
            </HBox>
         </top>
         <center>
            <HBox spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <VBox alignment="TOP_RIGHT" spacing="50.0">
                     <children>
                        <Label contentDisplay="RIGHT" text="Paid Date:" />
                        <Label contentDisplay="RIGHT" text="Bill Amount:" />
                        <Label contentDisplay="RIGHT" text="Adv. Amount Paid" />
                        <Label contentDisplay="RIGHT" text="Total Amount Paid:" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_RIGHT" minWidth="250.0" spacing="40.0">
                     <children>
                        <DatePicker fx:id="dpPaidDate" editable="false" prefHeight="25.0" prefWidth="250.0" promptText="From Date" />
                        <TextField fx:id="txtBillAmt" editable="false" focusTraversable="false" onKeyTyped="#allowNumberOnlyOnType" promptText="Actual Bill Amount" />
                        <TextField fx:id="txtPaidAmt" onKeyPressed="#txtGotAdvanceAmountOnPress" onKeyTyped="#txtGotAdvanceAmountOnTyped" promptText="Paid Amount" styleClass="custom-text-field" />
                        <TextField fx:id="txtTotalAmtPaidYet" editable="false" focusTraversable="false" onKeyTyped="#allowDotWithNumberOnType" promptText="Total Amount Paid Yet" />
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
               </children>
               <BorderPane.margin>
                  <Insets left="10.0" />
               </BorderPane.margin>
            </HBox>
         </center>
         <bottom>
            <HBox alignment="TOP_RIGHT" BorderPane.alignment="TOP_RIGHT">
               <children>
                  <Button mnemonicParsing="false" onAction="#onSaveClicked" text="Save" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
         </bottom>
      </BorderPane>
   </children>
</AnchorPane>
