                        <Button mnemonicParsing="false" onAction="#btReductionSelectAllOnAction" text="Select All" />
                        <Button layoutX="904.0" layoutY="12.0" mnemonicParsing="false" onAction="#btReductionDeSelectAllOnAction" text="De Select All" />
