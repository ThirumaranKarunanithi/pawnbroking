<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.cell.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="dialogpanel" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" styleClass="screen-background" stylesheets="@stockdetails.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.magizhchi.pawnbroking.reports.AllCompaniesListDialogUIController">
   <children>
      <AnchorPane>
         <children>
            <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <HBox alignment="CENTER" focusTraversable="true">
                     <children>
                        <TableView fx:id="tbReduce" editable="true" onMouseClicked="#tbAllDetailsOnMouseClicked" prefHeight="210.0">
                           <columns>
                              <TableColumn maxWidth="1000.0" minWidth="-1.0" prefWidth="50.0" text="Sl No">
                                 <cellValueFactory>
                                    <PropertyValueFactory property="sSlNo" />
                                 </cellValueFactory>
                              </TableColumn>
                              <TableColumn maxWidth="1000.0" minWidth="-1.0" prefWidth="200.0" text="Id">
                                 <cellValueFactory>
                                    <PropertyValueFactory property="sId" />
                                 </cellValueFactory>
                              </TableColumn>
                              <TableColumn prefWidth="200.0" text="Company Name">
                                 <cellValueFactory>
                                    <PropertyValueFactory property="sName" />
                                 </cellValueFactory>
                              </TableColumn>
