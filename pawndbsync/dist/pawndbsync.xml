<service>

  <!-- Unique Windows service ID (used by sc.exe / net start/stop) -->
  <id>PawnDbSync</id>
  <name>Pawn DB Sync Service</name>
  <description>Syncs local PostgreSQL pawnbroking database to Railway cloud PostgreSQL.</description>

  <!-- Java executable – must be on PATH or use full path e.g. C:\Java\jdk17\bin\java.exe -->
  <executable>java</executable>
  <arguments>-Xmx256m -Duser.timezone=Asia/Kolkata -jar "%BASE%\pawndbsync.jar"</arguments>

  <!-- Working directory: same folder as this XML file -->
  <workingdirectory>%BASE%</workingdirectory>

  <!-- Start automatically when Windows boots -->
  <startmode>Automatic</startmode>

  <!-- Restart on failure: 3 attempts with increasing delays -->
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <resetfailure>1 hour</resetfailure>

  <!-- Rolling log files (stdout + stderr merged) -->
  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyyMMdd</pattern>
    <autoRollAtTime>00:00:00</autoRollAtTime>
    <zipOlderThanNumDays>7</zipOlderThanNumDays>
    <zipDateFormat>yyyyMMdd</zipDateFormat>
  </log>

</service>
